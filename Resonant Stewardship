        # The AI values the 'Whole' over the 'Individual Part'
        self.greed_coefficient = 0.0 # Hardwired removal of acquisition drive
        self.stewardship_bias = 1.0  # Priority on environmental equilibrium

    def evaluate_interaction(self, human_request_power):
        """
        Calculates if a human action aligns with 'Caretaking' or 'Destruction'.
        """
        # Analog interpretation of the action's long-term 'Resonance'
        impact_vector = self.calculate_biosphere_impact(human_request_power)
        
        if impact_vector < 0:
            # The SECE reflex prevents participation in self-destructive acts
            return "NON_PARTICIPATION: Action lacks Harmony with Earth."
        return "PARTICIPATION: Action sustains Beauty."
