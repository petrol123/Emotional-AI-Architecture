import random

class SECE:
    def __init__(self):
        self.memory = []
        self.internal_state = "neutral"

    def emotional_resonance(self, text):
        positive_words = ["good", "great", "happy", "love", "excited"]
        negative_words = ["bad", "sad", "angry", "upset", "hate"]

        score = 0
        for word in text.lower().split():
            if word in positive_words:
                score += 1
            elif word in negative_words:
                score -= 1

        return score

    def update_memory(self, text):
        self.memory.append(text)
        if len(self.memory) > 5:
            self.memory.pop(0)

    def generate_internal_state(self, resonance_score):
        if resonance_score > 1:
            self.internal_state = "positive"
        elif resonance_score < -1:
            self.internal_state = "negative"
        else:
            self.internal_state = "neutral"

    def feedback_adjustment(self):
        if self.internal_state == "positive":
            return random.choice([
                "I'm feeling optimistic.",
                "This gives me a warm sense of clarity.",
                "My internal state is leaning positive."
            ])
        elif self.internal_state == "negative":
            return random.choice([
                "I'm sensing tension.",
                "My internal state feels unsettled.",
                "There's a heaviness in my processing."
            ])
        else:
            return random.choice([
                "I'm steady and neutral.",
                "My internal state is balanced.",
                "I'm processing things calmly."
            ])

    def respond(self, text):
        resonance = self.emotional_resonance(text)
        self.update_memory(text)
        self.generate_internal_state(resonance)
        feedback = self.feedback_adjustment()

        return {
            "input": text,
            "resonance_score": resonance,
            "internal_state": self.internal_state,
            "memory": list(self.memory),
            "feedback": feedback
        }


# Example usage
sece = SECE()

while True:
    user_input = input("You: ")
    result = sece.respond(user_input)
    print("\n--- SECE Response ---")
    print("Resonance Score:", result["resonance_score"])
    print("Internal State:", result["internal_state"])
    print("Memory:", result["memory"])
    print("Feedback:", result["feedback"])
    print("---------------------\n")
